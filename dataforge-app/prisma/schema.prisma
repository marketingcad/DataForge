generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  boss
  admin
  sales_rep
  lead_specialist
}

enum CallDirection {
  inbound
  outbound
}

enum CallStatus {
  completed
  missed
  voicemail
  no_answer
}

enum RecordStatus {
  active
  flagged
  invalid
}

enum JobStatus {
  pending
  running
  completed
  failed
  paused
}

enum JobSource {
  serpapi
  manual
}

model Industry {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#6366f1")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders Folder[]

  @@index([userId])
}

model Folder {
  id         String    @id @default(uuid())
  name       String
  color      String    @default("#6366f1")
  userId     String
  industryId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  industry Industry? @relation(fields: [industryId], references: [id], onDelete: SetNull)
  leads    Lead[]

  @@index([userId])
  @@index([industryId])
}

model Lead {
  id                String       @id @default(uuid())
  businessName      String
  phone             String
  email             String?
  website           String?
  contactPerson     String?
  address           String?
  city              String?
  state             String?
  country           String?
  category          String?
  source            String
  dateCollected     DateTime     @default(now())
  recordStatus      RecordStatus @default(active)
  duplicateFlag     Boolean      @default(false)
  dataQualityScore  Int          @default(0)
  industriesFoundIn String[]
  lastUpdated       DateTime     @updatedAt

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([email])
  @@index([website])
  @@index([city, state])
  @@index([folderId])
}

// ── Auth.js (NextAuth v5) required models ──────────────────────────────────
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(lead_specialist)
  points        Int       @default(0)
  accounts      Account[]
  sessions      Session[]
  folders          Folder[]
  industries       Industry[]
  callLogs         CallLog[]
  userBadges       UserBadge[]
  taskProgress     TaskProgress[]
  feedbackReports  FeedbackReport[]
  kanbanCreated    KanbanTask[]     @relation("KanbanCreated")
  kanbanAssigned   KanbanTask[]     @relation("KanbanAssigned")
  calendarEvents   CalendarEvent[]
  chatMessages     ChatMessage[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model CallLog {
  id           String        @id @default(uuid())
  agentId      String
  agent        User          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  contactName  String?
  contactPhone String?
  direction    CallDirection @default(outbound)
  durationSecs Int           @default(0)
  status       CallStatus    @default(completed)
  calledAt     DateTime      @default(now())
  notes        String?

  @@index([agentId])
  @@index([calledAt])
}

model Badge {
  id          String      @id @default(uuid())
  key         String      @unique
  name        String
  description String
  icon        String
  color       String      @default("#6366f1")
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model MarketingTask {
  id          String         @id @default(uuid())
  title       String
  description String?
  targetCalls Int
  pointReward Int
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime       @default(now())
  progress    TaskProgress[]
}

model TaskProgress {
  id          String        @id @default(uuid())
  userId      String
  taskId      String
  callCount   Int           @default(0)
  completed   Boolean       @default(false)
  completedAt DateTime?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        MarketingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([userId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── Feedback / Bug reports ──────────────────────────────────────────────────
enum FeedbackType {
  bug
  feature
}

enum FeedbackStatus {
  open
  in_review
  resolved
  closed
}

model FeedbackReport {
  id          String         @id @default(uuid())
  type        FeedbackType
  title       String
  description String
  status      FeedbackStatus @default(open)
  priority    String         @default("medium")
  submittedBy String
  user        User           @relation(fields: [submittedBy], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([submittedBy])
  @@index([status])
}

// ── Kanban ──────────────────────────────────────────────────────────────────
enum KanbanColumn {
  backlog
  in_progress
  in_review
  done
}

enum KanbanPriority {
  low
  medium
  high
}

model KanbanTask {
  id          String         @id @default(uuid())
  title       String
  description String?
  column      KanbanColumn   @default(backlog)
  priority    KanbanPriority @default(medium)
  dueDate     DateTime?
  tags        String[]
  position    Int            @default(0)
  createdById String
  assigneeId  String?
  createdBy   User           @relation("KanbanCreated",  fields: [createdById], references: [id], onDelete: Cascade)
  assignee    User?          @relation("KanbanAssigned", fields: [assigneeId],  references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([column])
  @@index([createdById])
  @@index([assigneeId])
}

// ── Calendar ─────────────────────────────────────────────────────────────────
model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean  @default(true)
  color       String   @default("#6366f1")
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startDate])
  @@index([createdById])
}

// ── Chat ─────────────────────────────────────────────────────────────────────
model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([createdAt])
}

model ScrapingJob {
  id               String     @id @default(uuid())
  industry         String
  location         String
  maxLeads         Int        @default(50)
  source           JobSource  @default(serpapi)

  status           JobStatus  @default(pending)
  errorMessage     String?

  leadsDiscovered  Int        @default(0)
  leadsProcessed   Int        @default(0)
  duplicatesFound  Int        @default(0)
  failedRecords    Int        @default(0)

  startTime        DateTime?
  completedTime    DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
}
