generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  active
  flagged
  invalid
}

enum JobStatus {
  pending
  running
  completed
  failed
  paused
}

enum JobSource {
  serpapi
  manual
}

model Lead {
  id                String       @id @default(uuid())
  businessName      String
  phone             String
  email             String?
  website           String?
  contactPerson     String?
  city              String?
  state             String?
  country           String?
  category          String?
  source            String
  dateCollected     DateTime     @default(now())
  recordStatus      RecordStatus @default(active)
  duplicateFlag     Boolean      @default(false)
  dataQualityScore  Int          @default(0)
  industriesFoundIn String[]
  lastUpdated       DateTime     @updatedAt

  @@index([phone])
  @@index([email])
  @@index([website])
  @@index([city, state])
}

model ScrapingJob {
  id               String     @id @default(uuid())
  industry         String
  location         String
  maxLeads         Int        @default(50)
  source           JobSource  @default(serpapi)

  status           JobStatus  @default(pending)
  errorMessage     String?

  leadsDiscovered  Int        @default(0)
  leadsProcessed   Int        @default(0)
  duplicatesFound  Int        @default(0)
  failedRecords    Int        @default(0)

  startTime        DateTime?
  completedTime    DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
}
