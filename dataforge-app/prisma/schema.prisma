generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  active
  flagged
  invalid
}

enum JobStatus {
  pending
  running
  completed
  failed
  paused
}

enum JobSource {
  serpapi
  manual
}

model Lead {
  id                String       @id @default(uuid())
  businessName      String
  phone             String
  email             String?
  website           String?
  contactPerson     String?
  city              String?
  state             String?
  country           String?
  category          String?
  source            String
  dateCollected     DateTime     @default(now())
  recordStatus      RecordStatus @default(active)
  duplicateFlag     Boolean      @default(false)
  dataQualityScore  Int          @default(0)
  industriesFoundIn String[]
  lastUpdated       DateTime     @updatedAt

  @@index([phone])
  @@index([email])
  @@index([website])
  @@index([city, state])
}

// ── Auth.js (NextAuth v5) required models ──────────────────────────────────
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model ScrapingJob {
  id               String     @id @default(uuid())
  industry         String
  location         String
  maxLeads         Int        @default(50)
  source           JobSource  @default(serpapi)

  status           JobStatus  @default(pending)
  errorMessage     String?

  leadsDiscovered  Int        @default(0)
  leadsProcessed   Int        @default(0)
  duplicatesFound  Int        @default(0)
  failedRecords    Int        @default(0)

  startTime        DateTime?
  completedTime    DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
}
